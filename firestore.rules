// firestore.rules
// Deploy these rules from the Firebase Console or using firebase-cli:
//   firebase deploy --only firestore:rules
//
// These rules enforce:
//  - Public read access for manga, chapters, and comments
//  - Only the admin email can write manga / chapters
//  - Authenticated users can post comments; only admin can delete them

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: is the requester our admin? ─────────────────────
    function isAdmin() {
      return request.auth != null
          && request.auth.token.email == "anwarbah96@gmail.com";
    }

    // ── Helper: is the user authenticated? ──────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    // ── Manga collection ────────────────────────────────────────
    match /manga/{mangaId} {
      // Anyone can read manga
      allow read: if true;

      // Only admin can create / update / delete manga
      allow write: if isAdmin();

      // ── Chapters sub-collection ──────────────────────────────
      match /chapters/{chapterId} {
        allow read: if true;
        allow write: if isAdmin();

        // ── Comments sub-collection ────────────────────────────
        match /comments/{commentId} {
          allow read: if true;

          // Any authenticated user can post a comment
          allow create: if isAuthenticated()
                        && request.resource.data.authorUid == request.auth.uid
                        && request.resource.data.text is string
                        && request.resource.data.text.size() > 0
                        && request.resource.data.text.size() <= 1000;

          // Only the comment author OR admin can delete
          allow delete: if isAdmin()
                        || (isAuthenticated()
                            && resource.data.authorUid == request.auth.uid);

          // Nobody can update an existing comment (immutable after posting)
          allow update: if false;
        }
      }
    }
  }
}
